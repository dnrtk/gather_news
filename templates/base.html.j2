<!DOCTYPE html>
<html lang="ja">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title>{% block title %}ニュースダイジェスト{% endblock %}</title>
  <style>
    :root {
      --sidebar-w: 240px;
      --bg: #ffffff;
      --bg-sidebar: #f3f4f6;
      --bg-card: #f9fafb;
      --fg: #111827;
      --fg-muted: #6b7280;
      --accent: #2563eb;
      --border: #e5e7eb;
      --btn-bg: #e5e7eb;
      --tier1: #7c3aed;
      --tier2: #0891b2;
      --tier3: #059669;
    }
    @media (prefers-color-scheme: dark) {
      :root {
        --bg: #111827;
        --bg-sidebar: #1f2937;
        --bg-card: #1f2937;
        --fg: #f9fafb;
        --fg-muted: #9ca3af;
        --accent: #60a5fa;
        --border: #374151;
        --btn-bg: #374151;
        --tier1: #a78bfa;
        --tier2: #22d3ee;
        --tier3: #34d399;
      }
    }
    * { box-sizing: border-box; margin: 0; padding: 0; }
    body {
      background: var(--bg);
      color: var(--fg);
      font-family: -apple-system, BlinkMacSystemFont, "Segoe UI", sans-serif;
      line-height: 1.7;
    }

    /* ── Hamburger ─────────────────────── */
    #hamburger {
      position: fixed;
      top: 0.75rem;
      left: 0.75rem;
      z-index: 300;
      width: 36px;
      height: 36px;
      border: none;
      border-radius: 6px;
      background: var(--btn-bg);
      color: var(--fg);
      font-size: 1.2rem;
      cursor: pointer;
      display: flex;
      align-items: center;
      justify-content: center;
    }
    #hamburger:hover { opacity: 0.8; }

    /* ── Sidebar ───────────────────────── */
    #sidebar {
      position: fixed;
      top: 0; left: 0; bottom: 0;
      width: var(--sidebar-w);
      background: var(--bg-sidebar);
      border-right: 1px solid var(--border);
      overflow-y: auto;
      z-index: 200;
      display: flex;
      flex-direction: column;
      transform: translateX(calc(-1 * var(--sidebar-w)));
      transition: transform 0.25s ease;
    }
    #sidebar.open   { transform: translateX(0); }
    #sidebar.closed { transform: translateX(calc(-1 * var(--sidebar-w))); }

    .sidebar-title {
      padding: 0.85rem 1rem 0.85rem 3.5rem;
      font-weight: 700;
      font-size: 0.9rem;
      border-bottom: 1px solid var(--border);
      flex-shrink: 0;
      white-space: nowrap;
      overflow: hidden;
      text-overflow: ellipsis;
    }
    #nav-list { flex: 1; padding: 0.5rem 0; }

    .nav-link {
      display: block;
      padding: 0.35rem 1rem;
      font-size: 0.875rem;
      color: var(--fg);
      text-decoration: none;
      border-radius: 0 4px 4px 0;
      margin-right: 0.5rem;
      white-space: nowrap;
      overflow: hidden;
      text-overflow: ellipsis;
    }
    .nav-link:hover {
      background: color-mix(in srgb, var(--accent) 12%, transparent);
      color: var(--accent);
    }
    .nav-link.active {
      background: color-mix(in srgb, var(--accent) 15%, transparent);
      color: var(--accent);
      font-weight: 600;
    }
    .nav-empty { padding: 1rem; font-size: 0.85rem; color: var(--fg-muted); }

    /* ── Overlay (mobile only) ─────────── */
    #overlay {
      display: none;
      position: fixed;
      inset: 0;
      background: rgba(0, 0, 0, 0.45);
      z-index: 150;
    }
    #overlay.show { display: block; }

    /* ── Main ──────────────────────────── */
    #main {
      min-height: 100vh;
      padding: 1.5rem 1rem 2rem 3.5rem;
      transition: margin-left 0.25s ease;
    }
    .content { max-width: 800px; }

    /* ── Desktop ───────────────────────── */
    @media (min-width: 768px) {
      #sidebar { transform: translateX(0); }
      #sidebar.closed { transform: translateX(calc(-1 * var(--sidebar-w))); }
      #main {
        margin-left: var(--sidebar-w);
        padding-left: 2rem;
        transition: margin-left 0.25s ease;
      }
      #main.sidebar-closed {
        margin-left: 0;
        padding-left: 3.5rem;
      }
      #overlay { display: none !important; }
    }

    {% block extra_styles %}{% endblock %}
  </style>
</head>
<body>
  <button id="hamburger" aria-label="メニュー">☰</button>

  <aside id="sidebar">
    <div class="sidebar-title">ニュースダイジェスト</div>
    <nav id="nav-list"><p class="nav-empty">読み込み中…</p></nav>
  </aside>

  <div id="overlay"></div>

  <main id="main">
    <div class="content">
      {% block content %}{% endblock %}
    </div>
  </main>

  <script>
    const NAV_ROOT = {{ nav_root | tojson }};

    const hamburger = document.getElementById('hamburger');
    const sidebar   = document.getElementById('sidebar');
    const overlay   = document.getElementById('overlay');
    const main      = document.getElementById('main');

    function isMobile() { return window.innerWidth < 768; }
    function isOpen()   { return sidebar.classList.contains('open') || (!isMobile() && !sidebar.classList.contains('closed')); }

    function openSidebar() {
      sidebar.classList.add('open');
      sidebar.classList.remove('closed');
      if (isMobile()) overlay.classList.add('show');
      else main.classList.remove('sidebar-closed');
    }
    function closeSidebar() {
      sidebar.classList.remove('open');
      sidebar.classList.add('closed');
      overlay.classList.remove('show');
      if (!isMobile()) main.classList.add('sidebar-closed');
    }

    // 初期状態: デスクトップは開く、モバイルは閉じる
    if (isMobile()) closeSidebar(); else openSidebar();

    hamburger.addEventListener('click', () => isOpen() ? closeSidebar() : openSidebar());
    overlay.addEventListener('click', closeSidebar);

    // ナビ読み込み
    const CURRENT_FILE = location.pathname.endsWith('/')
      ? 'index.html'
      : location.pathname.split('/').pop();

    async function loadNav() {
      try {
        const res = await fetch(NAV_ROOT + 'nav.json');
        if (!res.ok) throw new Error(res.status);
        const data = await res.json();

        let html = '';
        for (const page of data) {
          const filename = page.path.split('/').pop();
          const active   = CURRENT_FILE === filename ? ' active' : '';
          html += `<a href="${NAV_ROOT}${page.path}" class="nav-link${active}">${page.label}</a>`;
        }
        document.getElementById('nav-list').innerHTML = html || '<p class="nav-empty">ページなし</p>';
      } catch {
        document.getElementById('nav-list').innerHTML = '<p class="nav-empty">読み込み失敗</p>';
      }
    }
    loadNav();
  </script>
</body>
</html>
