{% extends "base.html.j2" %}

{% block title %}{{ title }}{% endblock %}

{% block extra_styles %}
header { margin-bottom: 2rem; padding-bottom: 1rem; border-bottom: 2px solid var(--border); }
header h1 { font-size: 1.4rem; margin-bottom: 0.25rem; }
header .meta { color: var(--fg-muted); font-size: 0.85rem; }

section { margin-bottom: 2.5rem; }
section h2 {
  font-size: 1rem;
  margin-bottom: 1rem;
  padding: 0.4rem 0.75rem;
  border-radius: 6px;
  border-left: 4px solid;
}
section.tier-1 h2 { border-color: var(--tier1); background: color-mix(in srgb, var(--tier1) 8%, transparent); }
section.tier-2 h2 { border-color: var(--tier2); background: color-mix(in srgb, var(--tier2) 8%, transparent); }
section.tier-3 h2 { border-color: var(--tier3); background: color-mix(in srgb, var(--tier3) 8%, transparent); }

.article-card {
  background: var(--bg-card);
  border: 1px solid var(--border);
  border-radius: 8px;
  padding: 1rem 1.25rem;
  margin-bottom: 0.75rem;
}
.article-card h3 { font-size: 1rem; margin-bottom: 0.3rem; }
.article-card h3 a { color: var(--fg); text-decoration: none; }
.article-card h3 a:hover { color: var(--accent); text-decoration: underline; }
.article-card .meta { color: var(--fg-muted); font-size: 0.8rem; margin-bottom: 0.5rem; }
.article-card .summary { font-size: 0.9rem; }
{% endblock %}

{% block content %}
<header>
  <h1>{{ title }}</h1>
  <p class="meta">生成日時: {{ generated_at }}</p>
</header>

{% for tier_num, tier_label in [(1, "🤖 AI一次情報"), (2, "💻 テック全般"), (3, "📰 その他")] %}
{% if tier_num in tier_groups %}
<section class="tier-{{ tier_num }}">
  <h2>{{ tier_label }}</h2>
  {% for article in tier_groups[tier_num] %}
  <div class="article-card">
    <h3><a href="{{ article.url }}" target="_blank" rel="noopener noreferrer">{{ article.title }}</a></h3>
    <p class="meta">{{ article.source_name }} | {{ article.published.strftime('%m/%d %H:%M') }}</p>
    <p class="summary">{{ article.summary }}</p>
  </div>
  {% endfor %}
</section>
{% endif %}
{% endfor %}
{% endblock %}
